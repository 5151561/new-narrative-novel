{
  "name": "@narrative-novel/renderer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "predev": "node ../../scripts/cleanup-debug-processes.mjs --scope renderer --quiet",
    "dev": "node ../../scripts/run-with-cleanup.mjs vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc --noEmit",
    "test": "node ../../scripts/run-with-cleanup.mjs vitest run",
    "test:watch": "node ../../scripts/run-with-cleanup.mjs vitest",
    "prestorybook": "node ../../scripts/cleanup-debug-processes.mjs --scope storybook --quiet",
    "storybook": "node ../../scripts/run-with-cleanup.mjs storybook dev -p 6006 --host 127.0.0.1 --no-open --exact-port",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@narrative-novel/fixture-seed": "workspace:*",
    "@tanstack/react-query": "^5.75.4",
    "clsx": "^2.1.1",
    "lucide-react": "^0.511.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.3.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/addon-links": "^8.6.14",
    "@storybook/blocks": "^8.6.14",
    "@storybook/react": "^8.6.14",
    "@storybook/react-vite": "^8.6.14",
    "@tailwindcss/forms": "^0.5.10",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.14.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.3",
    "storybook": "^8.6.14",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^6.3.3",
    "vitest": "^3.1.2"
  }
}
